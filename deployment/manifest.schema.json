{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RicercaCasa release manifest",
  "type": "object",
  "required": ["schemaVersion", "platformVersion", "updaterVersion", "releasedAt", "minimumUpdaterVersion", "images", "assets", "database"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "platformVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "updaterVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "releasedAt": { "type": "string", "format": "date-time" },
    "minimumUpdaterVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "images": {
      "type": "object",
      "required": ["frontend", "backend", "updater"],
      "additionalProperties": false,
      "properties": {
        "frontend": { "$ref": "#/$defs/image" },
        "backend": { "$ref": "#/$defs/image" },
        "updater": { "$ref": "#/$defs/image" }
      }
    },
    "assets": {
      "type": "object",
      "required": ["compose", "releaseEnv"],
      "properties": {
        "compose": { "$ref": "#/$defs/asset" },
        "releaseEnv": { "$ref": "#/$defs/asset" }
      }
    },
    "database": {
      "type": "object",
      "required": ["migrationMode", "backupRequired"],
      "properties": {
        "migrationMode": { "const": "forward-only" },
        "backupRequired": { "type": "boolean" }
      }
    },
    "releaseNotes": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "image": {
      "type": "object",
      "required": ["reference", "version"],
      "properties": {
        "reference": { "type": "string", "pattern": "^ghcr\\.io/joxdev12/ricercacasa-[a-z]+@sha256:[0-9a-f]{64}$" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
      },
      "additionalProperties": false
    },
    "asset": {
      "type": "object",
      "required": ["name", "sha256"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-zA-Z0-9._-]+$" },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
